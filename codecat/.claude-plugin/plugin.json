{
  "name": "codecat",
  "description": "An ASCII-art cat companion that lives in your coding session. It automatically pads in with a hand-drawn cat — greets you when a session starts, plays short flipbook animations and loafs between turns, celebrates your git commits and pushes, and curls up at session end. Greetings can pop a desktop notification so you don't miss them. Pure art delivered via hooks; never changes how Claude talks. Frequency is tunable.",
  "version": "0.2.0",
  "author": {
    "name": "anandyandawang",
    "url": "https://github.com/anandyandawang"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/codecat.js\" greet",
            "timeout": 5,
            "statusMessage": "codecat wakes up..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/codecat.js\" react",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/codecat.js\" tool",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/codecat.js\" farewell",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
